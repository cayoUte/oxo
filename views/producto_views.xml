<odoo>
    <record id="view_oxxo_producto_form" model="ir.ui.view">
        <field name="name">oxxo.producto.form</field>
        <field name="model">oxoo.producto</field>
        <field name="arch" type="xml">
        
            <form string="Productos OXXO">
                             
                <sheet>
                 <div class = "oe_title">
                 <label for ="nombre"/>
                    <h1>
                    <field name= "nombre" placehorder="Ejemplo:Gorra Negra"/>
                    </div>        
                 <group>
                    <group string ="Información Principal">
                    <field name="codigo"/>
                    <field name="tipo_producto"/>
                    <field name="precio_venta"/>
                    </group> 

                  <group string="Descripcion">
                    <field name="descripcion"/>
                   </group>
                   </group>
   
                </sheet>      
            </form>    
        </field>    
    </record>

    <record id="view_oxxo_producto_list" model="ir.ui.view">
        <field name="name">oxxo.producto.list</field>
        <field name="model">oxxo.producto</field>
        <field name="arch" type="xml">

            <list string="Productos OXXO">
                <field name="codigo"/>
                <field name="nombre"/>
                <field name="tipo_producto"/>
                <field name="precio_venta"/>
            </list>        
        </field>    
    </record>




    <record id='acction_oxxo_producto' model="ir.actions.act_window">
        <field name="name">PRODUCTOS OXXO</field>
        <field name="res_model">oxxo.producto</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU DEL OXXO-->
    
    <menuitem id="menu_oxxo_producto" name="OXXO" sequence="10"/>

    <menuitem id="menu_oxxo_producto"
              name="Producto"
              parent="menu_oxxo_root"
              action="action_oxxo_producto"
              sequence="1"/>

</odoo>